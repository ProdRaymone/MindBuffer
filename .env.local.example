# ---------- Supabase ----------
# From Supabase Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here

# Service role key (server-only, for agent pull mode)
# Never expose to client. Used only in /api/agent-pull endpoint.
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# ---------- Anthropic ----------
# For server-side digest generation.
#
# Option A: official Anthropic API
ANTHROPIC_API_KEY=sk-ant-...
#
# Option B: relay / proxy compatible with the Anthropic SDK
# Leave ANTHROPIC_API_KEY empty when using auth token mode.
ANTHROPIC_AUTH_TOKEN=
ANTHROPIC_BASE_URL=

# ---------- App ----------
# Used for OAuth redirects + absolute URLs.
# Local: http://localhost:3000
# Prod:  https://mindbuffer-raymone.vercel.app (or your custom domain)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ---------- Agent Pull (optional) ----------
# A random secret for /api/agent-pull. Only your Claude Code knows this.
# Generate with: openssl rand -hex 32
AGENT_PULL_TOKEN=generate_a_random_hex_string_here
